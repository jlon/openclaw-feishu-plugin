{
  "name": "@openclaw/feishu",
  "version": "2026.3.8-beta.1",
  "description": "OpenClaw Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:local": "bash scripts/sync-to-installed-extension.sh",
    "e2e:group": "tsx scripts/feishu-group-e2e.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@sinclair/typebox": "0.34.48",
    "https-proxy-agent": "^7.0.6",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": "^2026.3.8"
  },
  "devDependencies": {
    "openclaw": "^2026.3.8",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@openclaw/feishu",
      "localPath": "extensions/feishu",
      "defaultChoice": "npm"
    }
  }
}
